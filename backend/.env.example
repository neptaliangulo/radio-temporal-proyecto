# Puerto del servidor
PORT=3001

# MongoDB Atlas — sustituye por tu cadena de conexion
MONGODB_URI=mongodb+srv://USUARIO:PASSWORD@CLUSTER.mongodb.net/radio-temporal?retryWrites=true&w=majority

# Clave para firmar los JWT (genera una aleatoria larga, p.ej. con: openssl rand -hex 64)
JWT_SECRET=tu_clave_secreta_muy_larga_y_aleatoria_aqui

# Cloudinary — sustituye por tus credenciales
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Origen del frontend para CORS (cambia en produccion)
FRONTEND_URL=http://localhost:5173
